{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FICC Observor Result",
  "type": "object",
  "required": ["answer", "confidence", "freshness_cutoff"],
  "properties": {
    "title": { "type": "string" },
    "answer": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "freshness_cutoff": { "type": "string", "format": "date-time" },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "ref_id": { "type": "string" },
          "title": { "type": "string" },
          "uri": { "type": "string" },
          "published_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}

