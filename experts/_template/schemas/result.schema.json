{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "COVA Expert Result",
  "type": "object",
  "required": ["answer", "confidence", "freshness_cutoff"],
  "properties": {
    "title": { "type": "string" },
    "answer": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "freshness_cutoff": { "type": "string", "format": "date-time" },
    "references": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}

